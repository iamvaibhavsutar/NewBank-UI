VITE_API_BASE_URL=/api               //This is used when npm run build is used inside Docker,
                                        //Since the frontend and backend are in the same container, we can use /api to refer to the backend.
                                        //When running npm run dev, it will use the value from .env which is http://localhost:8080/api
                                        //Nginx will proxy requests from /api to the backend server running on port 8080.